rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function companyKeys() {
      return [
        'id',
        'name',
        'industry',
        'jobType',
        'desireLevel',
        'difficultyLevel',
        'priority',
        'status',
        'myPageRegistered',
        'esStatus',
        'aptitudeTestStatus',
        'interviewSchedule',
        'internshipStatus',
        'applyDate',
        'esDeadline',
        'internshipDeadline',
        'nextDeadline',
        'nextAction',
        'companyMemo',
        'motivationMemo',
        'esMemo',
        'interviewMemo',
        'questionMemo',
        'myPageUrl',
        'recruitUrl',
        'tags',
        'createdAt',
        'updatedAt'
      ];
    }

    function validCompany(companyId) {
      return request.resource.data.keys().hasOnly(companyKeys())
        && request.resource.data.id == companyId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.industry is string
        && request.resource.data.jobType is string
        && request.resource.data.desireLevel in ['本命', '高', '中', '低', '未設定']
        && request.resource.data.difficultyLevel in ['高', '中', '低', '未設定']
        && request.resource.data.priority in ['高', '中', '低']
        && request.resource.data.status is string
        && request.resource.data.myPageRegistered is bool
        && request.resource.data.esStatus is string
        && request.resource.data.aptitudeTestStatus is string
        && request.resource.data.interviewSchedule is string
        && request.resource.data.internshipStatus is string
        && request.resource.data.applyDate is string
        && request.resource.data.esDeadline is string
        && request.resource.data.internshipDeadline is string
        && request.resource.data.nextDeadline is string
        && request.resource.data.nextAction is string
        && request.resource.data.companyMemo is string
        && request.resource.data.motivationMemo is string
        && request.resource.data.esMemo is string
        && request.resource.data.interviewMemo is string
        && request.resource.data.questionMemo is string
        && request.resource.data.myPageUrl is string
        && request.resource.data.recruitUrl is string
        && request.resource.data.tags is list
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    match /companies/{companyId} {
      allow read: if true;
      allow create, update: if validCompany(companyId);
      allow delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
